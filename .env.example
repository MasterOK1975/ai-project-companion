# AI Project Companion
# Версия: 1.0.0

# Переменные окружения (скопируй в .env)
BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Для Whisper (опционально)
DATABASE_URL=sqlite:///data/projects.db  # Для PostgreSQL: postgresql://user:pass@localhost/db
AI_MODEL=openai/gpt-4o  # Модель для анализа